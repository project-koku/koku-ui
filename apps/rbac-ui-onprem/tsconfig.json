{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@redhat-cloud-services/*": ["../../libs/onprem-cloud-deps/src/*"],
      "@unleash/*": ["../../libs/onprem-cloud-deps/src/unleash/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
