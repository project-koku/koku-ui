{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "types": ["@testing-library/jest-dom", "jest", "node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "baseUrl": "./src",
    "outDir": "./dist/",
    "paths": {
      "@koku-ui/ui-lib/*": [
        "../../../libs/ui-lib/src/*"
      ],
      "@redhat-cloud-services/frontend-components-notifications": [
        "../../../libs/onprem-cloud-deps/src/frontend-components-notifications"
      ],
      "@redhat-cloud-services/frontend-components-notifications/*": [
        "../../../libs/onprem-cloud-deps/src/frontend-components-notifications/*"
      ],
      "@redhat-cloud-services/*": [
        "../../../libs/onprem-cloud-deps/src/*"
      ],
    }
  },
  "include": [
    "src/**/*",
  ],
}