{
  "name": "@koku-ui/ui-lib",
  "version": "0.0.1",
  "description": "Library of common components and utilities",
  "repository": "https://github.com/project-koku/koku-ui.git",
  "author": "Red Hat",
  "license": "Apache-2.0",
  "private": true,
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./components/page/uiVersion": {
      "types": "./dist/src/components/page/uiVersion/index.d.ts",
      "webpack": "./src/components/page/uiVersion/index.ts",
      "import": "./dist/src/components/page/uiVersion/index.js",
      "require": "./dist/src/components/page/uiVersion/index.js",
      "default": "./dist/src/components/page/uiVersion/index.js"
    },
    "./components/page/notFound": {
      "types": "./dist/src/components/page/notFound/index.d.ts",
      "webpack": "./src/components/page/notFound/index.ts",
      "import": "./dist/src/components/page/notFound/index.js",
      "require": "./dist/src/components/page/notFound/index.js",
      "default": "./dist/src/components/page/notFound/index.js"
    },
    "./*": {
      "webpack": "./src/*",
      "types": "./dist/src/*.d.ts",
      "import": "./dist/src/*.js",
      "require": "./dist/src/*.js",
      "default": "./dist/src/*.js"
    }
  },
  "scripts": {
    "prebuild": "tsc --noEmit && rimraf dist",
    "build": "tsc --build && npm run copy:css",
    "check:dependencies": "npx npm-check-updates",
    "check:dependencies:update": "npx npm-check-updates -u",
    "clean": "rimraf dist",
    "copy:css": "rsync -Rurv --include '*/' --include '*.css' --exclude '*' src  dist",
    "dev": "tsc -w",
    "lint": "npm-run-all lint:*",
    "lint:ts": "eslint src",
    "lint:ts:fix": "eslint src --fix",
    "test": ""
  },
  "dependencies": {
    "@patternfly/patternfly": "6.4.0",
    "@patternfly/react-core": "6.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
